import java.util.Scanner;
import java.util.ArrayList;
 class produto {
    String nome;
    int quantidade;
    double preco;
    String pratilheira;

     public static void main(String args[]) {
         Scanner e = new Scanner(System.in);
         ArrayList <produto> lista =new ArrayList<>();
         String nome;
         System.out.println("Informe seu primeiro e último nome:");
         nome = e.nextLine();

         String senha = "";
         System.out.println("Informe uma senha de no mínimo 8 caracteres:");
         senha = e.nextLine();

         while (senha.length() < 8) {
             System.out.println("Senha inválida, tente novamente:");
             senha = e.nextLine();
         }

         String  confisenha;



         System.out.println("Confirme sua senha:");
         confisenha = e.nextLine();

         if (confisenha.equals(senha)) {
             System.out.println("Login realizado com sucesso!");
                System.out.println("bem-vindo "+nome );
             char opcao = '0';

             while (opcao != '5') {
                 System.out.println("===== MENU =====");
                 System.out.println("1 - Cadastrar produto");
                 System.out.println("2 - Lista de produtos");
                 System.out.println("3 - Remover produto");
                 System.out.println("4 - Atualizar produto");
                 System.out.println("5 - Sair");

                 opcao = e.next().charAt(0);

                 switch(opcao) {
                     case '1':
                         e.nextLine();

                         System.out.println("Informe o nome do produto:");
                         String nomeProd = e.nextLine();

                         System.out.println("Informe a quantidade do produto:");
                         int qnt = e.nextInt();

                         System.out.println("Informe o preço do produto:");
                         double preco = e.nextDouble();
                         e.nextLine();

                         System.out.println("informe a pratilheira ");
                         String pratilheira = e.nextLine();

                             produto p = new produto();
                         p.nome = nomeProd;
                         p.quantidade = qnt;
                         p.preco = preco;
                         p.pratilheira = pratilheira;

                         lista.add(p);

                         System.out.println("Produto cadastrado com sucesso!");

                         System.out.println("Cadastrando produto...");
                         break;
                     case '2' :
                     if (lista.isEmpty()) {
                         System.out.println("Nenhum produto cadastrado.");
                     } else {
                         System.out.println("=== LISTA DE PRODUTOS ===");

                         for (produto prod : lista) {
                             System.out.println("Nome: " + prod.nome);
                             System.out.println("Quantidade: " + prod.quantidade);
                             System.out.println("Preço: R$ " + prod.preco);
                             System.out.println("Guardado em: " + prod.pratilheira);
                         }
                     }
                     break;
                     case '3':
                         System.out.println("Removendo produto...");
                         break;
                     case '4':
                         System.out.println("Atualizando produto...");
                         break;
                     case '5':
                         System.out.println("Saindo...");
                         break;
                     default:
                         System.out.println("Opção inválida!");
                 }
             }

         } else {
             System.out.println("Senha incorreta!");
         }
     }
 }

